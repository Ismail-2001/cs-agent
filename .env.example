# --- Tenant (required — one deployed instance per client) ---
# This is a deployment label, NOT a row-level filter. Every instance serves exactly
# one client. If you're deploying a second client, deploy a separate instance with
# its own .env and database.
TENANT_NAME=your-client-name

# --- LLM (required — pick ONE primary provider) ---
# Provider priority: GROQ_API_KEY > GOOGLE_API_KEY > OPENROUTER_API_KEY
# Only the highest-priority one needs to be set. Set ANTHROPIC_API_KEY for fallback.

# Option A: Groq (fast, cheap, open-source models). Get a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Option B: OpenRouter (gpt-4o-mini). Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Option C: Google Gemini (fallback or embeddings). Get a key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Fallback: Claude Haiku. Add an Anthropic key and it's used automatically when
# the primary provider has an outage.
ANTHROPIC_API_KEY=your-anthropic-api-key
FALLBACK_MODEL=claude-haiku-4-5-20251001

# --- Shopify (required for order lookups) ---
# Create a custom app: Shopify Admin > Settings > Apps and sales channels > Develop apps
# Scopes needed: read_orders
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx

# --- Gorgias (required for ticket sync) ---
# API key: Gorgias > Settings > REST API
GORGIAS_DOMAIN=your-store
GORGIAS_EMAIL=you@yourstore.com
GORGIAS_API_KEY=your-gorgias-api-key
# Set this to any random string, and put the SAME value as a custom header
# named "x-webhook-secret" on the Gorgias webhook you configure.
GORGIAS_WEBHOOK_SECRET=change-me-to-a-random-string

# --- Automation policy ---
# Start with AUTO_SEND_ENABLED=false. Every reply becomes a draft/internal note in Gorgias
# for a human to approve. Once you trust the agent's judgment on a given client (usually after
# a week or two of reviewing drafts), flip this to true.
AUTO_SEND_ENABLED=false
AUTO_SEND_MIN_CONFIDENCE=0.85
AUTO_SEND_BLOCKED_CATEGORIES=refund,complaint,legal,other

# Path to the SQLite DB. On Render free plan this is ephemeral — wiped on
# every deploy. Acceptable for MVP. Upgrade to Render Starter ($7/mo) for a
# persistent disk if you need data to survive restarts.
DB_PATH=cs_agent.db
ENV=development

# --- API Security ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-generate-a-real-random-key
REQUIRE_API_KEY=true
# Comma-separated. Your dashboard's domain(s) only. Leave empty to block ALL browser calls.
ALLOWED_ORIGINS=
RATE_LIMIT_PER_MINUTE=60
REFUND_RATE_LIMIT_PER_MINUTE=10
RESEND_RATE_LIMIT_PER_MINUTE=10

# Cost governance
DAILY_COST_CAP_USD=5.0

# Secret for the generic /webhooks/inbound endpoint (WhatsApp/chat-widget/etc).
# Generate the same way as API_KEY above.
INBOUND_WEBHOOK_SECRET=change-me-generate-a-real-random-key
